generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("POSTGRES_PRISMA_URL")
}

model Plantation {
  id             Int           @id @default(autoincrement())
  slNo           Int
  district       String
  upazila        String
  union          String
  village        String
  block          String?
  geo            String?       // "lat, lng"
  address        String?
  date           String        // YYYY-MM-DD
  ndvi           String?
  remarks        String?
  caretakerName  String
  caretakerMobile String
  saaoName       String?
  saaoMobile     String?
  officerName    String?
  officerMobile  String?
  submittedAt    DateTime      @default(now())
  seedlings      Seedling[]
}

model Seedling {
  id           Int        @id @default(autoincrement())
  name         String     // "আম", "সেগুন", etc.
  category     String     // "ফলজ", "বনজ", "ঔষধি"
  count        Int
  plantationId Int
  plantation   Plantation @relation(fields: [plantationId], references: [id], onDelete: Cascade)
}